{
  "name": "sgc",
  "private": true,
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File start.ps1 -Mode dev",
    "dev:direct": "concurrently -n backend,frontend -c cyan,magenta \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && venv\\Scripts\\python -m alembic upgrade head && venv\\Scripts\\python -m app.seed && venv\\Scripts\\python -m uvicorn app.main:app --reload --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-server.ps1",
    "start:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-server.ps1",
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-server.ps1",
    "backup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backup.ps1",
    "install:all": "pip install -r backend\\requirements.txt && cd frontend && npm install",
    "migrate": "backend\\venv\\Scripts\\python -m alembic upgrade head",
    "seed": "backend\\venv\\Scripts\\python -m app.seed",
    "status": "powershell -NoProfile -ExecutionPolicy Bypass -File start.ps1 -Mode status",
    "infra:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/infra/setup.ps1",
    "infra:setup:quick": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/infra/setup.ps1 -Quick -NoTunnel",
    "infra:start": "powershell -NoProfile -ExecutionPolicy Bypass -File start.ps1 -Mode infra",
    "infra:deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/infra/deploy.ps1",
    "infra:monitor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/infra/monitor.ps1",
    "infra:tunnel:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/infra/tunnel.ps1 -Action install",
    "infra:tunnel:login": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/infra/tunnel.ps1 -Action login",
    "infra:tunnel:create": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/infra/tunnel.ps1 -Action create",
    "infra:tunnel:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/infra/tunnel.ps1 -Action start",
    "infra:tunnel:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/infra/tunnel.ps1 -Action stop",
    "infra:tunnel:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/infra/tunnel.ps1 -Action status",
    "infra:tunnel:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/infra/tunnel.ps1 -Action uninstall",
    "infra:webhook:start": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Start-Process -WindowStyle Hidden -FilePath 'backend\\venv\\Scripts\\python.exe' -ArgumentList 'scripts/infra/webhook-server.py'\"",
    "sync": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/infra/sync.ps1",
    "sync:push": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/infra/sync.ps1 -Action push",
    "sync:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/infra/sync.ps1 -Action status",
    "sync:log": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/infra/sync.ps1 -Action log"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
